# Backend environment variables
# Copy this to .env and fill in your values

# Shared secret between frontend and backend
BACKEND_API_KEY=change-me-to-a-random-secret-string

# Path to the project root (where run_crew.py and clients/ folder live)
# Use absolute path in production
PROJECT_ROOT=..

# Path to clients folder (relative to PROJECT_ROOT or absolute)
CLIENTS_DIR=clients

# Anthropic API key (for chat feature)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Python executable to use for running crew scripts
# Use the venv python in production
PYTHON_EXEC=python

# CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:3000
